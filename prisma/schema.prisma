generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum pour les rôles d'utilisateur
enum Role {
  CLIENT
  EXPERT
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  role           Role      @default(CLIENT)
  company        String?
  avatar         String?
  description    String?
  location       String?
  experience     String?
  skills         String[]
  portfolio      Json?
  isVerified         Boolean   @default(false)
  twoFactorSecret    String?
  isTwoFactorEnabled Boolean   @default(false)
  proposals      Proposal[]
  messages       Message[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  clientProjects Project[] @relation("ClientProjects")
  expertProjects Project[] @relation("ExpertProjects")
  files          File[]
  audits         Audit[]   @relation("ExpertAudits")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  budget      String?
  timeline    String?
  techStack      String[]
  githubRepoUrl  String?
  status         String   @default("matching") // matching, in_progress, review, completed
  clientId    String
  client      User     @relation("ClientProjects", fields: [clientId], references: [id])
  expertId    String?
  expert      User?    @relation("ExpertProjects", fields: [expertId], references: [id])
  proposals   Proposal[]
  milestones  Milestone[]
  messages    Message[]
  files       File[]
  audits      Audit[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Proposal {
  id             String   @id @default(uuid())
  approach       String
  methodology    String
  experience     String?
  proposedPrice  String
  timeline       String
  status         String   @default("pending") // pending, accepted, rejected
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  expertId       String
  expert         User     @relation(fields: [expertId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Milestone {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("pending") // pending, in_progress, completed
  dueDate     DateTime?
  amount      Float?
  deliverables String[]
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id          String   @id @default(uuid())
  content     String
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  createdAt   DateTime @default(now())
}

model File {
  id          String   @id @default(uuid())
  name        String
  type        String
  size        String
  path        String
  category    String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id])
  createdAt   DateTime @default(now())
}

model Audit {
  id              String   @id @default(uuid())
  securityScore   Int
  qualityScore    Int
  conformityScore Int
  status          String   @default("PENDING") // PENDING, PASSED, FAILED
  aiReport        String   @db.Text
  expertComments  String?  @db.Text
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  expertId        String
  expert          User     @relation("ExpertAudits", fields: [expertId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
